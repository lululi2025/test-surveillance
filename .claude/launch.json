{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "image-prompt-fill (Vite + React)",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/vite", "--host", "0.0.0.0", "--port", "1420"],
      "port": 1420,
      "cwd": "image-prompt-fill"
    },
    {
      "name": "landing-page-preview",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');const base=p.join(process.cwd(),'outputs/marketing-content/ai-cloud-surveillance-landing-page');h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':decodeURIComponent(q.url);let fp=p.join(base,u);let ext=p.extname(fp).toLowerCase();let ct={'':' text/html','.html':'text/html','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.svg':'image/svg+xml','.webp':'image/webp'}[ext]||'application/octet-stream';f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':ct});r.end(d);}});}).listen(3456)"],
      "port": 3456
    },
    {
      "name": "remotion-studio",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/remotion", "studio", "src/index.ts", "--port", "3457"],
      "port": 3457,
      "cwd": "remotion-animations"
    }
  ]
}
